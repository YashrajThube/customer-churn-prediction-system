VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_API_KEY=

# Power BI embedding fallback (frontend-only local development)
# Production should use backend token broker endpoint: /powerbi/embed-config.
VITE_POWERBI_CLIENT_ID=
VITE_POWERBI_TENANT_ID=
VITE_POWERBI_EMBED_URL=
VITE_POWERBI_REPORT_ID=
VITE_POWERBI_ACCESS_TOKEN=
VITE_POWERBI_TOKEN_TYPE=Embed

# Legacy compatibility keys (if migrating from Create React App)
REACT_APP_POWERBI_CLIENT_ID=
REACT_APP_POWERBI_TENANT_ID=
REACT_APP_POWERBI_REPORT_ID=

# Dataset mapping for app-driven slicers
VITE_POWERBI_TABLE_NAME=customers
VITE_POWERBI_RISK_COLUMN=risk_level
VITE_POWERBI_CONTRACT_COLUMN=contract_type
VITE_POWERBI_CUSTOMER_COLUMN=customer_id

# Optional drillthrough page name (for report.setPage)
VITE_POWERBI_DRILLTHROUGH_PAGE=
VITE_POWERBI_SLICER_ENABLED=true
